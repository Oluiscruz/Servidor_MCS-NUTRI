    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "googleapis": "^170.1.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "render-cli": "^0.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supabase": "^2.76.17"
