{
  "name": "nutrims-backend",
  "version": "1.0.0",
  "description": "API Node.js para gestão de clínica nutricional com PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node migrate.js && node server.js",
    "build": "rm -rf node_modules/bcrypt && npm install bcrypt --build-from-source",
    "migrate": "node migrate.js",
    "dev": "nodemon server.js"
  },
  "keywords": [
    "node",
    "express",
    "postgresql",
    "pg",
    "cors",
    "bcryptjs",
    "nutrição"
